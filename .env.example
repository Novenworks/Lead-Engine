# LeadEngine by Novenworks — Environment Variables

# PostgreSQL database connection (auto-set by Replit when you provision a database)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Session signing secret — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# Resend API key — get one at https://resend.com
# Used to send lead notification emails to client notification emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
